{
    "name": "adil-l/mahungu.co.mz",
    "description": "Mahungu flyer studio with Laravel backend.",
    "type": "project",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.11",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "league/flysystem-aws-s3-v3": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        },
        "audit": {
            "block-insecure": false
        }
    }
}
