{
    "name": "adil-l/mahungu.co.mz",
    "description": "Mahungu flyer studio with Laravel backend.",
    "type": "project",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.11",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        }
    }
}
