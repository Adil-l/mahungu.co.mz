APP_NAME="Mahungu Studio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mahungu.co.mz
FRONTEND_URL=https://mahungu.co.mz

LOG_CHANNEL=stack
LOG_LEVEL=error

# Base de dados (MySQL/MariaDB em produção)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mahungu
DB_USERNAME=forge
DB_PASSWORD=

# Sessões / cache
BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Fila — usa "database" e corre um worker no Forge (Daemon)
QUEUE_CONNECTION=database

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Email — preencher com SMTP real para recuperação de palavra-passe
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@mahungu.co.mz"
MAIL_FROM_NAME="${APP_NAME}"

# Redes sociais (OAuth) — preencher conforme integração
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# AWS S3 (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
