APP_NAME="Mahungu Studio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mahungu.co.mz
FRONTEND_URL=https://mahungu.co.mz

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─────────────────────────────────────────────────────────────
# Base de dados — no Laravel Cloud as credenciais são INJETADAS
# automaticamente pela plataforma (não precisas de as preencher aqui).
# Mantém estes nomes para deploys fora do Cloud (local/Forge/VPS).
# ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mahungu
DB_USERNAME=
DB_PASSWORD=

# Sessões / cache
BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Segurança: cookie de sessão só por HTTPS em produção (NUNCA false em produção).
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Fila — no Laravel Cloud configura-se um Worker no painel; localmente usa "database".
QUEUE_CONNECTION=database

# Redis (opcional — no Laravel Cloud é fornecido como add-on)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────
# Email — obrigatório para recuperação de palavra-passe
# ─────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@mahungu.co.mz"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────
# IA — geração de conteúdo editorial (headlines/legendas)
# ─────────────────────────────────────────────────────────────
# Gemini: usado no cliente (browser) — chave por utilizador nas Definições.
GEMINI_API_KEY=

# Claude (Anthropic): provider server-side, a chave fica AQUI (nunca no browser).
# É o provedor preferencial do ai.js. Obter chave em console.anthropic.com.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=4096

# ─────────────────────────────────────────────────────────────
# Redes sociais — OAuth e tokens
# ─────────────────────────────────────────────────────────────
# Facebook / Instagram (Meta)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Página FB usada para publicar e ler métricas/insights reais
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Scopes OAuth (têm de existir na app da Meta, senão dá "Invalid Scopes").
# Deixa em branco para usar os predefinidos do config/services.php.
FACEBOOK_SCOPES=
INSTAGRAM_SCOPES=

# X / Twitter — conta da marca (OAuth 1.0a para publicar + OAuth2/Bearer para ler)
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Threads (Meta)
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_SCOPES=

# TikTok (scopes — em branco usa os predefinidos do config/services.php)
TIKTOK_SCOPES=

# Modo simulação: true marca os posts como publicados sem chamar as APIs reais
# (demonstra o agendamento sem a aprovação da Meta). Em produção: false.
SOCIAL_SIMULATE=false

# ─────────────────────────────────────────────────────────────
# Serviços externos (proxies com chaves do lado do servidor)
# ─────────────────────────────────────────────────────────────
# Gerador de hashtags (RapidAPI / Hashtagy)
RAPIDAPI_KEY=
RAPIDAPI_HASHTAG_HOST=

# Pesquisa de imagens de reforço (chaves do lado do servidor)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────
# Pusher (broadcasting em tempo real — opcional)
# ─────────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─────────────────────────────────────────────────────────────
# Armazenamento de objetos — Cloudflare R2 (compatível com S3)
# Usado para flyers/imagens partilhadas. No Laravel Cloud podes usar
# o bucket gerido ou apontar para o R2 com endpoint compatível.
# ─────────────────────────────────────────────────────────────
# Disco predefinido e disco de media (flyers/imagens). Para R2 usa "s3".
FILESYSTEM_DISK=local
MEDIA_DISK=s3
MEDIA_VISIBILITY=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true
